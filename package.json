{
	"name": "n8n-nodes-letmepost",
	"version": "0.1.4",
	"description": "n8n community node for letmepost.dev — publish to Bluesky, X/Twitter, LinkedIn, Instagram, Threads, Facebook, Pinterest and TikTok through one API, with preflight validation and transparent errors.",
	"license": "MIT",
	"homepage": "https://letmepost.dev",
	"keywords": [
		"n8n-community-node-package",
		"letmepost",
		"social-media",
		"publishing",
		"bluesky",
		"twitter",
		"linkedin",
		"instagram",
		"threads",
		"pinterest",
		"tiktok"
	],
	"author": {
		"name": "letmepost.dev",
		"email": "kamal@letmepost.dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/letmepost/n8n-nodes-letmepost.git"
	},
	"bugs": {
		"url": "https://github.com/letmepost/n8n-nodes-letmepost/issues"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/LetmepostApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Letmepost/Letmepost.node.js",
			"dist/nodes/LetmepostTrigger/LetmepostTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
